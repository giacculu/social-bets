# Database - Supabase PostgreSQL
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Auth
AUTH_SECRET="genera-con: npx openssl rand -base64 32"
NEXTAUTH_URL="https://your-app.vercel.app"

# Data Collection Sources (opzionale - il sistema funziona anche senza)
# The Odds API - https://the-odds-api.com/ (500 req/mese gratis)
THE_ODDS_API_KEY="your-odds-api-key"

# Football-Data.org - https://www.football-data.org/ (10 req/min gratis)
FOOTBALL_DATA_API_KEY="your-football-data-key"

# Vercel Cron (generato automaticamente su Vercel)
CRON_SECRET="genera-con: npx openssl rand -base64 32"
