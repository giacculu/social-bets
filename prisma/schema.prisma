generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum EventStatus {
  UPCOMING
  LIVE
  FINISHED
  CANCELLED
  POSTPONED
}

enum MarketType {
  MATCH_RESULT
  OVER_UNDER
  BOTH_TEAMS_SCORE
  HANDICAP
  FIRST_SCORER
  CORRECT_SCORE
  DOUBLE_CHANCE
  CUSTOM
}

enum MarketStatus {
  OPEN
  SUSPENDED
  CLOSED
  SETTLED
}

enum BetStatus {
  PENDING
  LOCKED
  WON
  LOST
  VOID
  CASHED_OUT
}

enum BetResult {
  WIN
  LOSS
  VOID
}

enum PredictionStatus {
  ACTIVE
  LOCKED
  CORRECT
  INCORRECT
  VOID
}

enum CustomBetStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum ParticipantStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ParticipantResult {
  WIN
  LOSS
  DRAW
  NO_SHOW
}

enum ContestStatus {
  DRAFT
  OPEN
  LOCKED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ContestVisibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum EntryStatus {
  REGISTERED
  CONFIRMED
  DISQUALIFIED
  COMPLETED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_PLACED
  BET_WON
  BET_LOST
  BET_CANCELLED
  BET_REFUND
  DAILY_BONUS
  REFERRAL_BONUS
  CUSTOM_BET_ENTRY
  CUSTOM_BET_WON
  CHALLENGE_WON
  CHALLENGE_LOST
  CHALLENGE_REFUND
  ADMIN_ADJUSTMENT
}

enum RealTransactionType {
  DEPOSIT
  WITHDRAWAL
  CONTEST_ENTRY
  CONTEST_WIN
  CONTEST_REFUND
  REFERRAL_BONUS
  ADMIN_ADJUSTMENT
}

enum RealTxStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum FeedVisibility {
  PUBLIC
  FRIENDS
  PRIVATE
}

enum ActivityType {
  PREDICTION
  PREDICTION_RESULT
  BET_PLACED
  BET_WON
  BET_LOST
  CONTEST_CREATED
  CONTEST_JOINED
  CONTEST_WON
  CHALLENGE_CREATED
  CHALLENGE_ACCEPTED
  CHALLENGE_WON
  FRIEND_ADDED
  ACHIEVEMENT_EARNED
  STREAK_MILESTONE
}

enum ActivityTarget {
  EVENT
  CONTEST
  CHALLENGE
  USER
  PREDICTION
  BET
}

enum NotificationType {
  BET_RESULT
  CONTEST_UPDATE
  CHALLENGE_REQUEST
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  ACHIEVEMENT
  LEADERBOARD_CHANGE
  SYSTEM
}

enum CommentTarget {
  EVENT
  CONTEST
  CHALLENGE
}

enum ReactionTarget {
  PREDICTION
  COMMENT
  ACTIVITY
  EVENT
}

enum SyncJobStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum DataSource {
  THE_ODDS_API
  FOOTBALL_DATA_ORG
  MANUAL
}

enum AchievementType {
  FIRST_PREDICTION
  FIRST_WIN
  WIN_STREAK_5
  WIN_STREAK_10
  WIN_STREAK_25
  PERFECT_WEEK
  ALL_CORRECT
  CHALLENGE_WON_10
  CONTEST_WINNER
  SPORT_EXPERT
  SOCIAL_BUTTERFLY
  REFERRAL_MASTER
  EARLY_ADOPTER
}

// ─── Auth & Users ────────────────────────────────────────────

// ARCHITECTURE NOTE — AdminActionLog (future, M7+):
// Every privileged admin operation MUST be logged to an AdminActionLog table:
//   - adminUserId: who performed the action
//   - action: enum (SETTLE_BET, ADJUST_BALANCE, BAN_USER, MODIFY_CONTEST, etc.)
//   - targetType: enum (USER, BET, CONTEST, EVENT, SYSTEM)
//   - targetId: ID of the affected entity
//   - metadata: Json (before/after snapshots, reason, ip)
//   - createdAt: DateTime
// This is required for wallet operations, contest management, and manual settlements.
// Implement as part of M7 (Features) when admin pages are rebuilt.

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  username              String    @unique
  name                  String?
  avatarUrl             String?
  passwordHash          String
  inviteCode            String    @unique
  referredBy            String?
  role                  UserRole  @default(USER)
  version               Int       @default(1)
  emailVerified         DateTime?
  onboardingCompleted   Boolean   @default(false)
  preferredSports       String[]
  timezone              String?   @default("UTC")
  locale                String?   @default("en")
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  wallet                Wallet?
  bets                  Bet[]
  predictions           Prediction[]
  customBetsCreated     CustomBet[]            @relation("CustomBetCreator")
  customBetParticipants CustomBetParticipant[]
  transactions          Transaction[]
  friendshipsSent       Friendship[]           @relation("FriendshipInitiator")
  friendshipsReceived   Friendship[]           @relation("FriendshipReceiver")
  leaderboardEntries    LeaderboardEntry[]
  contestsCreated       Contest[]              @relation("ContestCreator")
  contestEntries        ContestEntry[]
  realTransactions      RealTransaction[]
  achievements          Achievement[]
  reputation            Reputation?
  activityFeedEntries   ActivityFeedEntry[]
  notifications         Notification[]
  comments              Comment[]
  reactions             Reaction[]
  userStats             UserStats?
  referrer              User?                  @relation("ReferralSource", fields: [referredBy], references: [inviteCode])
  referralsGiven        User[]                 @relation("ReferralSource")

  @@index([role, deletedAt])
}

// ─── Wallet ──────────────────────────────────────────────────

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Decimal  @default(10000) @db.Decimal(12, 2)
  frozenBalance Decimal  @default(0) @db.Decimal(12, 2)
  currency      String   @default("EUR")
  version       Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── Sports Data ─────────────────────────────────────────────

model Sport {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  leagues League[]
}

model League {
  id        String   @id @default(cuid())
  sportId   String
  name      String
  slug      String
  country   String?
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  sport   Sport    @relation(fields: [sportId], references: [id])
  events  Event[]

  @@unique([sportId, slug])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  sportId   String
  createdAt DateTime @default(now())

  homeEvents Event[] @relation("HomeTeam")
  awayEvents Event[] @relation("AwayTeam")

  @@index([sportId])
}

model Event {
  id            String    @id @default(cuid())
  leagueId      String
  sportId       String?
  externalId    String?   @unique
  homeTeamId    String?
  awayTeamId    String?
  homeTeamName  String
  awayTeamName  String
  startTime     DateTime
  status        EventStatus @default(UPCOMING)
  result        String?
  scoreHome     Int?
  scoreAway     Int?
  slug          String?
  metadata      Json?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  league     League      @relation(fields: [leagueId], references: [id])
  homeTeam   Team?       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team?       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  markets    Market[]
  bets       Bet[]
  predictions Prediction[]
  contests   Contest[]
  stats      EventStats?

  @@index([leagueId])
  @@index([sportId, status])
  @@index([startTime])
  @@index([status])
}

// ─── Markets & Odds ──────────────────────────────────────────

model Market {
  id          String        @id @default(cuid())
  eventId     String
  name        String
  slug        String
  type        MarketType
  status      MarketStatus  @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event    Event      @relation(fields: [eventId], references: [id])
  bets     Bet[]
  predictions Prediction[]
  outcomes Outcome[]

  @@unique([eventId, slug])
  @@index([eventId])
}

model Outcome {
  id          String   @id @default(cuid())
  marketId    String
  name        String
  slug        String
  odds        Decimal  @db.Decimal(8, 2)
  probability Float?
  settled     Boolean  @default(false)
  result      Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  market      Market       @relation(fields: [marketId], references: [id])
  bets        Bet[]
  predictions Prediction[]

  @@unique([marketId, slug])
  @@index([marketId])
}

// ─── Bets (Stake-Based, Virtual Currency) ────────────────────

model Bet {
  id              String    @id @default(cuid())
  userId          String
  eventId         String
  marketId        String
  outcomeId       String
  stake           Decimal   @db.Decimal(10, 2)
  odds            Decimal   @db.Decimal(8, 2)
  potentialWin    Decimal   @db.Decimal(10, 2)
  confidence      Int?
  isPublic        Boolean   @default(true)
  status          BetStatus @default(PENDING)
  settled         Boolean   @default(false)
  result          BetResult?
  lockedAt        DateTime?
  settledAt       DateTime?
  deletedAt       DateTime?
  version         Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  event   Event   @relation(fields: [eventId], references: [id])
  market  Market  @relation(fields: [marketId], references: [id])
  outcome Outcome @relation(fields: [outcomeId], references: [id])

  @@index([userId, settled])
  @@index([status])
}

// ─── Predictions (Free Picks) ───────────────────────────────

model Prediction {
  id          String           @id @default(cuid())
  userId      String
  eventId     String
  marketId    String
  outcomeId   String
  confidence  Int?
  isPublic    Boolean          @default(true)
  score       Float?
  status      PredictionStatus @default(ACTIVE)
  settledAt   DateTime?
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user    User    @relation(fields: [userId], references: [id])
  event   Event   @relation(fields: [eventId], references: [id])
  market  Market  @relation(fields: [marketId], references: [id])
  outcome Outcome @relation(fields: [outcomeId], references: [id])

  @@index([userId, settledAt])
  @@index([eventId, settledAt])
  @@index([outcomeId])
}

// ─── Custom Bets (Virtual Currency) ──────────────────────────

model CustomBet {
  id          String          @id @default(cuid())
  creatorId   String
  title       String
  description String?
  stake       Decimal         @db.Decimal(10, 2)
  deadline    DateTime
  status      CustomBetStatus @default(PENDING)
  result      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  creator      User                  @relation("CustomBetCreator", fields: [creatorId], references: [id])
  participants CustomBetParticipant[]
}

model CustomBetParticipant {
  id          String   @id @default(cuid())
  customBetId String
  userId      String
  prediction  String
  status      ParticipantStatus @default(PENDING)
  result      ParticipantResult?
  createdAt   DateTime @default(now())

  customBet CustomBet @relation(fields: [customBetId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([customBetId, userId])
}

// ─── Contests (REAL MONEY - Skill-Based, NOT gambling) ──────

model Contest {
  id                   String           @id @default(cuid())
  creatorId            String
  title                String
  description          String?
  entryFee             Decimal          @db.Decimal(10, 2)
  maxPlayers           Int              @default(10)
  prizePool            Decimal          @default(0) @db.Decimal(12, 2)
  platformFee          Decimal          @default(0.10) @db.Decimal(4, 3)
  status               ContestStatus    @default(OPEN)
  visibility           ContestVisibility @default(PUBLIC)
  autoSettle           Boolean          @default(true)
  predictionsRequired  Json?
  startTime            DateTime
  endTime              DateTime
  result               String?
  cancelledAt          DateTime?
  deletedAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  creator  User           @relation("ContestCreator", fields: [creatorId], references: [id])
  entries  ContestEntry[]
  event    Event?         @relation(fields: [eventId], references: [id])
  eventId  String?

  @@index([status, startTime])
  @@index([creatorId])
}

model ContestEntry {
  id          String          @id @default(cuid())
  contestId   String
  userId      String
  predictions Json
  score       Float           @default(0)
  payout      Decimal         @default(0) @db.Decimal(12, 2)
  status      EntryStatus     @default(REGISTERED)
  createdAt   DateTime        @default(now())

  contest Contest @relation(fields: [contestId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([contestId, userId])
}

// ─── Social ──────────────────────────────────────────────────

model Friendship {
  id          String           @id @default(cuid())
  initiatorId String
  receiverId  String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  initiator User @relation("FriendshipInitiator", fields: [initiatorId], references: [id])
  receiver  User @relation("FriendshipReceiver", fields: [receiverId], references: [id])

  @@unique([initiatorId, receiverId])
  @@index([receiverId])
}

model Comment {
  id         String        @id @default(cuid())
  userId     String
  targetType CommentTarget
  targetId   String
  content    String
  parentId   String?
  deletedAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([targetType, targetId, createdAt])
}

model Reaction {
  id         String         @id @default(cuid())
  userId     String
  targetType ReactionTarget
  targetId   String
  emoji      String         @db.VarChar(4)
  createdAt  DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId, emoji])
  @@index([targetType, targetId])
}

model ActivityFeedEntry {
  id         String         @id @default(cuid())
  userId     String
  type       ActivityType
  targetType ActivityTarget
  targetId   String
  metadata   Json?
  visibility FeedVisibility @default(PUBLIC)
  createdAt  DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([type, createdAt])
}

// ─── Notifications ───────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  body       String
  data       Json?
  readAt     DateTime?
  pushSentAt DateTime?
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
}

// ─── Achievements ────────────────────────────────────────────

model Achievement {
  id        String          @id @default(cuid())
  userId    String
  type      AchievementType
  earnedAt  DateTime        @default(now())
  metadata  Json?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

// ─── Reputation ──────────────────────────────────────────────

model Reputation {
  id            String   @id @default(cuid())
  userId        String   @unique
  score         Int      @default(0)
  predictions   Int      @default(0)
  correct       Int      @default(0)
  winRate       Float    @default(0)
  streak        Int      @default(0)
  bestStreak    Int      @default(0)
  lastActiveAt  DateTime?
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── User Stats (Pre-computed Aggregates) ────────────────────

model UserStats {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalBets       Int      @default(0)
  wonBets         Int      @default(0)
  lostBets        Int      @default(0)
  voidBets        Int      @default(0)
  totalStaked     Decimal  @default(0) @db.Decimal(12, 2)
  totalWon        Decimal  @default(0) @db.Decimal(12, 2)
  totalLost       Decimal  @default(0) @db.Decimal(12, 2)
  netProfit       Decimal  @default(0) @db.Decimal(12, 2)
  winRate         Float    @default(0)
  avgOdds         Float?
  bestWinStreak   Int      @default(0)
  currentStreak   Int      @default(0)
  lastBetAt       DateTime?
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ─── Event Stats ─────────────────────────────────────────────

model EventStats {
  id             String   @id @default(cuid())
  eventId        String   @unique
  totalBets      Int      @default(0)
  totalPredictions Int    @default(0)
  totalStaked    Decimal  @default(0) @db.Decimal(12, 2)
  uniqueUsers    Int      @default(0)
  updatedAt      DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id])
}

// ─── Virtual Transactions ────────────────────────────────────

model Transaction {
  id        String          @id @default(cuid())
  userId    String
  type      TransactionType
  amount    Decimal         @db.Decimal(12, 2)
  balance   Decimal         @db.Decimal(12, 2)
  reference String?
  metadata  Json?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// ─── Real Money Transactions ─────────────────────────────────

model RealTransaction {
  id        String              @id @default(cuid())
  userId    String
  type      RealTransactionType
  amount    Decimal             @db.Decimal(12, 2)
  balance   Decimal             @db.Decimal(12, 2)
  status    RealTxStatus        @default(COMPLETED)
  reference String?
  metadata  Json?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

// ─── Leaderboard ─────────────────────────────────────────────

model LeaderboardEntry {
  id        String   @id @default(cuid())
  userId    String
  period    String
  totalWon  Decimal  @default(0) @db.Decimal(12, 2)
  totalLost Decimal  @default(0) @db.Decimal(12, 2)
  netProfit Decimal  @default(0) @db.Decimal(12, 2)
  winRate   Float    @default(0)
  betCount  Int      @default(0)
  rank      Int?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, period])
  @@index([period, netProfit(sort: Desc)])
}

// ─── Sync Jobs ───────────────────────────────────────────────

model SyncJob {
  id              String       @id @default(cuid())
  source          DataSource
  status          SyncJobStatus @default(RUNNING)
  startedAt       DateTime     @default(now())
  completedAt     DateTime?
  eventsProcessed Int?
  error           String?
  metadata        Json?

  @@index([source, startedAt])
}

// ─── Idempotency (financial operations) ──────────────────────

model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  userId    String
  operation String
  result    Json?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([key])
  @@index([expiresAt])
}
